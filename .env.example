# Notion Integration
NOTION_TOKEN=ntn_your_notion_integration_token
NOTION_DATABASE_ID=your_32_char_database_id

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gmail (for sending emails)
# Use an App Password, not your regular password
# Get one at: myaccount.google.com > Security > App passwords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Cron job secret (generate with: openssl rand -hex 32)
CRON_SECRET=your_random_secret

# Your name (used in AI-generated email sign-offs)
FREELANCER_NAME=Your Name

# AI generation tuning (optional — these are the defaults)
# DRAFT_WORD_LIMIT=120
# SENT_HISTORY_LIMIT=3
# DRAFT_HISTORY_LIMIT=10

# AI Providers — add comma-separated keys for rotation and fallback
# At least one provider is required
GEMINI_API_KEYS=key1,key2,key3
ANTHROPIC_API_KEYS=key1,key2
DEEPSEEK_API_KEYS=key1,key2
GROQ_API_KEYS=key1,key2
HUGGINGFACE_API_KEYS=key1,key2

# Optional: override the HuggingFace model (default: Qwen/Qwen2.5-72B-Instruct)
# HF_MODEL=meta-llama/Llama-3.2-3B-Instruct
